{
  "name": "electron-blink1-toy",
  "version": "0.9.0",
  "description": "Play with Electron and node-hid",
  "repository": "todbot/electron-blink1-toy",
  "author": "Tod Kurt <todbotdotcom@gmail.com> (https://github.com/todbot)",
  "license": "ISC",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "build:dir": "vite build && electron-builder --dir",
    "clean": "npx rimraf dist dist-electron release node_modules package-lock.json"
  },
  "keywords": [
    "hid",
    "node-hid",
    "blink(1)",
    "blink1",
    "usb",
    "electron"
  ],
  "build": {
    "appId": "com.todbot.electron-blink1-toy",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "pkg/icon.icns"
    },
    "win": {
      "target": "zip",
      "icon": "pkg/icon.ico"
    }
  },
  "dependencies": {
    "node-blink1": "^0.5.1",
    "react-bootstrap": "^2.10.10",
    "tinycolor2": "^1.4.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.0",
    "bootstrap": "^5.3.8",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^6.1.3",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}
